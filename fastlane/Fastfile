default_platform(:android)

platform :android do

  desc "Build debug APK and distribute via Firebase App Distribution"
  lane :firebase_dist do

    # Step 1: Clean the project
    gradle(task: "clean")

    # Step 2: Build debug APK
    gradle(
      task: "assemble",
      build_type: "Debug"
    )

    # Step 3: Upload to Firebase App Distribution
    firebase_app_distribution(
      app: ENV["FIREBASE_APP_ID"],
      groups: ENV["FIREBASE_TESTER_GROUP"],
      release_notes: "Build ##{ENV['BUILD_NUMBER']} - #{Time.now.strftime('%Y-%m-%d %H:%M')}",
      firebase_cli_token: ENV["FIREBASE_TOKEN"]
    )

  end

end